# Frontend MQTT WSS — credenciais compartilhadas (read-only)
# Estas variaveis sao injetadas em build time pelo Vite.
# Use o client `webapp-readonly` do Mosquitto (criado pela E2.2).
VITE_MQTT_WSS_URL=wss://hub.xtconect.online:8884/
VITE_MQTT_USER=webapp-readonly
VITE_MQTT_PASSWORD=<copiar de /opt/xtconect/env/mqtt-webapp-readonly-password>
