# XT Connect Hub — secrets.env.example
#
# Copiar para `infra/env/secrets.env` e preencher com valores reais.
# O arquivo real está no .gitignore — NUNCA commitar valores verdadeiros.
#
# Geradores úteis:
#   Senhas fortes ........: openssl rand -base64 32
#   Tokens curtos ........: openssl rand -hex 16
#   JWT secret (≥ 64 B) ..: openssl rand -base64 64
#   bcrypt hash p/ Node-RED: docker run --rm nodered/node-red-docker bash -c \
#       "node -e \"console.log(require('bcryptjs').hashSync('PASSWORD',10))\""

# ─── Domínio e Let's Encrypt ─────────────────────────────────────────
DOMAIN=hub.xtconect.online
LE_EMAIL=<<REDACTED — email do admin p/ notificações do certbot>>

# ─── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=xtconect
POSTGRES_PASSWORD=<<REDACTED — openssl rand -base64 32>>
POSTGRES_DB=xtconect

# ─── InfluxDB (telemetria de alta resolução) ─────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=<<REDACTED — openssl rand -base64 32>>
INFLUX_ORG=xtconect
INFLUX_BUCKET=telemetry
INFLUX_ADMIN_TOKEN=<<REDACTED — openssl rand -hex 32>>

# ─── Grafana (dashboards internos) ───────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<<REDACTED — openssl rand -base64 32>>

# ─── Node-RED ────────────────────────────────────────────────────────
NODERED_ADMIN_USER=admin
NODERED_ADMIN_PASSWORD=<<REDACTED — senha que vai gerar o hash abaixo>>
# Hash bcrypt da senha acima (ver gerador no topo)
NODERED_ADMIN_HASH=<<REDACTED — bcrypt hash de NODERED_ADMIN_PASSWORD>>
# Usado para criptografar flows_cred.json (NÃO mudar após configurado sem reset de credenciais)
NODERED_CREDENTIAL_SECRET=<<REDACTED — openssl rand -hex 32>>

# ─── MQTT (bridge/reservado) ─────────────────────────────────────────
# Contas legacy mantidas pra compat; uso ativo é via MQTT_INGEST_* e MQTT_WEBAPP_READONLY_*
MQTT_BRIDGE_USER=bridge
MQTT_BRIDGE_PASSWORD=<<REDACTED>>
MQTT_WEB_USER=webapp
MQTT_WEB_PASSWORD=<<REDACTED>>

# ─── MQTT: Node-RED ingest (publish em stat/# / app/#) ───────────────
MQTT_INGEST_USER=nodered-ingest
# Senha em arquivo mountado no container (ver scripts/dynsec_bootstrap.sh)
MQTT_INGEST_PASSWORD_FILE=/run/secrets/mqtt_ingest_password

# ─── MQTT: Webapp read-only (assina cmnd/<device>/#) ─────────────────
MQTT_WEBAPP_READONLY_USER=webapp-readonly
MQTT_WEBAPP_READONLY_PASSWORD_FILE=/run/secrets/mqtt_webapp_readonly_password

# ─── JWT (login webapp) ──────────────────────────────────────────────
JWT_SECRET=<<REDACTED — openssl rand -base64 64>>

# ─── Webapp admin (seed do primeiro user) ────────────────────────────
WEBAPP_ADMIN_PASSWORD=<<REDACTED>>

# ─── SMTP (transacional: verificação email / reset de senha) ─────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=conect@xtautomatize.com.br
# Senha em arquivo mountado no container
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
MAIL_FROM="XT Connect <conect@xtautomatize.com.br>"
MAIL_BASE_URL=https://hub.xtconect.online
